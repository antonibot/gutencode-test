# requests.http — every route, clickable.
#   VS Code: install the REST Client extension (humao.rest-client) · JetBrains IDEs: built in.
#   Start the app first:  python dev.py   (serves on :8080)
#
# 1) send 'register' once, then 'login' — the @token line below captures its access_token
#    automatically (VS Code REST Client). JetBrains: send login, then paste the value into @token.
# 2) every request below reuses {{token}}. The status in each comment is what the shipped contract
#    expects in ITS test order — your data will differ, the shapes won't.

@host = http://127.0.0.1:8080

### ── start here — mint a real session token ──────────────────────────
# @name register
POST {{host}}/auth/register
Content-Type: application/json

{"email": "alice@ex.com", "password": "correct horse"}

###
# @name login
POST {{host}}/auth/login
Content-Type: application/json

{"email": "alice@ex.com", "password": "correct horse"}

###
@token = {{login.response.body.access_token}}
GET {{host}}/auth/me
Authorization: Bearer {{token}}

### ── admin — Identity & access ──────────────────────
# POST /admin/actions  ·  the contract expects 201
POST {{host}}/admin/actions
Authorization: Bearer admin_dev_token_change_me
Content-Type: application/json

{"action": "deactivate_user", "target": "alice"}

###
# GET /admin/actions  ·  the contract expects 200
GET {{host}}/admin/actions
Authorization: Bearer admin_dev_token_change_me

###
# GET /admin/actions/{action_id}  ·  the contract expects 200
GET {{host}}/admin/actions/1
Authorization: Bearer admin_dev_token_change_me

