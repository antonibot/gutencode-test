# Configuration knobs — copy what you need into your environment. Defaults work out of the box.

# runtime — storage backend (SQLite by default; zero extra deps)
DATABASE_PATH=        # SQLite file path -> durable state across restarts; unset = in-memory
PORT=                 # go/node serve port (default 8080); python: pass it to uvicorn --port (docs use 8080)
HOST=                 # go/node bind address (default 127.0.0.1 = this machine only). Containers/PaaS
                      # need 0.0.0.0 — the shipped Dockerfiles set it; python binds via uvicorn --host.
CORS_ALLOWED_ORIGINS= # browser clients: comma-separated exact origins to allow via CORS, e.g.
                      # https://app.example.com,http://localhost:3000 (or * for any); unset = off
SERVICE_TOKEN=        # internal service credential: gates background-job claim/complete + audit-event
                      # ingestion. Ships with a known dev default — ROTATE IN PRODUCTION:
                      #   python -c "import secrets; print(secrets.token_urlsafe(32))"
LOG_LEVEL=            # set to 'silent' to suppress the per-request structured access-log line

# runtime — sessions (identity lifetime & rotation; all optional, sane defaults)
SESSION_TTL_SECONDS=         # absolute session lifetime in seconds (default 604800 = 7 days; min 60)
SESSION_REFRESH_SECONDS=     # idle-sliding re-extension throttle (default 86400 = at most once/day)
SESSION_REUSE_GRACE_SECONDS= # grace for a benign rotated-token retry before reuse-detection revokes (default 10)
STORE_OP_TIMEOUT_MS=         # go/node only: per store-operation timeout in ms (default 10000 = 10s)

# runtime — Postgres backend (OPTIONAL: Supabase or any Postgres). Set DATABASE_URL and it is used
# instead of SQLite; unset = SQLite via DATABASE_PATH above. All three runtimes (python, go, node)
# support it. One install step per language — see CUSTOMIZE.md:
#   python:  pip install 'psycopg[binary]'
#   go:      go get github.com/jackc/pgx/v5  &&  go build -tags postgres ./...
#   node:    npm install pg   (optional dep, lazy-loaded only for Postgres — SQLite default stays zero-dep)
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
# Supabase: use the CONNECTION POOLER endpoint (transaction mode, port 6543) for serverless/many workers,
# e.g. postgres://postgres.<ref>:PASSWORD@aws-0-<region>.pooler.supabase.com:6543/postgres
# SECURE_DELETE_ACK=1   # REQUIRED on Postgres: acknowledges that Postgres cannot scrub deleted bytes on
#                       # delete the way SQLite's secure_delete does (deleted rows persist in dead tuples
#                       # until VACUUM, and in replicas/backups) — rely on at-rest encryption / a key-
#                       # destruction (crypto-shred) scheme for true revocation of secrets.

# admin
ADMIN_TOKEN=admin_dev_token_change_me    # the admin bearer secret (rotate in production)

# agent
AI_PROVIDER=fake    # the LLM provider slot (ONE knob shared by the agent runtime and the /ai gateway): fake (deterministic, offline) is the zero-config default; anthropic or openai runs the SHIPPED stdlib adapter for that provider once its key env is set — a real name whose key env is missing, or any other value, makes every provider-invoking route FAIL LOUD (501 problem+json naming exactly what to set — see INTEROP.md), never a silent fake completion
ANTHROPIC_API_KEY=    # the Anthropic API key the shipped anthropic adapter sends as x-api-key — required (non-empty) when AI_PROVIDER=anthropic; read from env per call, never baked into code, never echoed in errors
OPENAI_API_KEY=    # the OpenAI API key the shipped openai adapter sends as a Bearer token — required (non-empty) when AI_PROVIDER=openai; read from env per call, never baked into code, never echoed in errors
AI_MODEL=    # the model id a wired real provider serves — ONE configured model per deployment, so spend stays operator-controlled; empty = the provider's default (anthropic: claude-sonnet-4-6, openai: gpt-4o); ignored by the offline fake
AI_TIMEOUT_SECONDS=60    # per-call ceiling on a real provider's HTTP round-trip, clamped to 1..600; a timeout or network failure maps to a loud 504 problem+json (never billed, never cached); the offline fake never waits
AI_MAX_TOKENS=1024    # the completion-token ceiling sent to providers that require one (anthropic's max_tokens; floored at 1); openai's ceiling is left to the model default
ANTHROPIC_BASE_URL=https://api.anthropic.com    # the Anthropic endpoint base — point it at a proxy/gateway or a local test double to reroute the anthropic adapter without code changes
OPENAI_BASE_URL=https://api.openai.com    # the OpenAI endpoint base — point it at a proxy/gateway or any OpenAI-compatible server to reroute the openai adapter without code changes
AGENT_MAX_ITERATIONS=6    # the run-loop terminate guard (the loop can NEVER exceed this)
AGENT_HISTORY_MAX=200    # per-session conversation buffer cap (ring-buffer, drop-oldest) — bounds the stored history, the per-turn feed, and GET /messages; floored at AGENT_MAX_ITERATIONS+2 so a SINGLE run never evicts its own user turn (concurrent runs on ONE session share the buffer and may evict each other's turns — size for expected per-session concurrency, or serialize; an active-run lock is the proposed v2)
AGENT_MAX_MSG_CHARS=4000    # per-message size cap (codepoints) — each stored message is middle-truncated (head + marker + tail) so a giant tool observation or user input can't flood the buffer or the next prompt; floored at 64
SSE_CHUNK_CODEPOINTS=12    # the streamed run response's delta window in CODE POINTS — with ?stream=1 (or Accept: text/event-stream) the final output is chopped into fixed codepoint chunks at the transport (the run loop is untouched), so the SSE frames always concatenate back to exactly the sync output; floored at 1
AI_USAGE_METER_FAKE=0    # arm usage metering for the offline fake provider — with '1' a fake run records a zero-cost llm_usage event (the offline-provable metering wire), so the whole agent->meter->summary path can be exercised with no keys; default '0' keeps the fake free and unmetered (a real provider ALWAYS meters). Read at call time

# ai_memory
AI_MEMORY_MAX_MEMORIES=1000    # max memories kept per scope (past the cap the expired-first, then lowest-importance/oldest memory is evicted)
AI_MEMORY_MAX_CONTENT_BYTES=16384    # max bytes of a memory's content (larger is rejected 422)
AI_MEMORY_MAX_METADATA_BYTES=4096    # max bytes of a memory's JSON metadata (larger is rejected 422)
AI_MEMORY_MAX_SCOPES=100    # per-owner scope cap (soft-DoS ceiling)
AI_MEMORY_MAX_TAGS=20    # max tags per memory (more is rejected 422)

# auth
AUTH_PBKDF2_ITERATIONS=200000    # PBKDF2-HMAC-SHA256 work factor (clamped to the ASVS 2.4.3 floor of 100000)
AUTH_THROTTLE_LIMIT=10    # max attempts per fixed window per (action,email) on the pre-auth endpoints
AUTH_THROTTLE_WINDOW=300    # the throttle window in seconds
AUTH_RESET_TTL_SECONDS=3600    # password-reset token lifetime (single-use)
AUTH_VERIFY_TTL_SECONDS=86400    # email-verification token lifetime (single-use)
AUTH_REQUIRE_VERIFIED=    # when '1', login requires a verified email (default off)

# chat_threads
CHAT_THREADS_MAX_THREADS=500    # max threads kept per user (a create past the cap is rejected with 422; delete a thread to free its slot)
CHAT_THREADS_MAX_MESSAGES=1000    # max messages kept per thread (an append past the cap is rejected with 422 - history is never silently evicted)
CHAT_THREADS_MAX_CONTENT_BYTES=16384    # max size of one message's content in bytes

# evals
EVALS_MAX_CASES=500    # max cases in one suite (soft-DoS ceiling; a create with more is 422)
EVALS_MAX_EXPECTED_BYTES=8192    # max code points in a case's expected value (422 beyond)
EVALS_MAX_OUTPUT_BYTES=65536    # max code points in a scored output (422 beyond)

# file_store
FILE_STORE_PROVIDER=store    # object backend: store (durable, default) or s3 (fail-loud stub - requires FILE_STORE_S3_BUCKET + FILE_STORE_S3_ENDPOINT)
FILE_STORE_MAX_BYTES=524288    # max DECODED object size in bytes (default 512 KiB). The wire cap is 1 MiB and base64 inflates 4/3, so the honest ceiling is 3*floor((1048576 - ~28 byte envelope)/4) ~= 786000; a larger value would always 413 (clamped to [1, 786000])
FILE_STORE_MAX_KEYS=1000    # per-owner file-COUNT cap - a create past it is 422 (clamped to [1, 10000]; the index row is rewritten through the write-lock-holding do() on every mutation, so it stays bounded)
FILE_STORE_MAX_TOTAL_BYTES=52428800    # per-owner total-BYTES quota (default 50 MiB; clamped to [1, 2^40])
FILE_STORE_S3_BUCKET=    # s3 provider: the bucket name (required when FILE_STORE_PROVIDER=s3) - NOT S3_BUCKET, which belongs to the storage domain
FILE_STORE_S3_ENDPOINT=    # s3 provider: the endpoint URL (required when FILE_STORE_PROVIDER=s3)

# invitations
INVITATIONS_TTL=604800    # default invite lifetime in seconds (7 days)

# job_queue
JOB_QUEUE_MAX_ATTEMPTS=20    # default delivery attempts before a job is dead-lettered (a per-job override is allowed, 1..1000)
JOB_QUEUE_BACKOFF_BASE_SECONDS=2    # retry backoff base: run_at advances by min(base * 2^attempts, cap)
JOB_QUEUE_BACKOFF_CAP_SECONDS=3600    # retry backoff ceiling in seconds
JOB_QUEUE_VISIBILITY_SECONDS=300    # lease duration: a claimed job whose lease lapses is reclaimable

# llm_usage
LLM_USAGE_MAX_TOKENS=10000000    # per-dimension token sanity ceiling (a larger count is rejected 422)
LLM_USAGE_REPLAY_WINDOW=300    # seconds; anti-backdate window for the usage `at` timestamp

# orgs
ORGS_INVITE_TTL_SECONDS=604800    # lifetime of a member-invite token in seconds (7 days); the invite is PENDING until accepted, after which the token is unusable
ORGS_DENY_AUDIT_LIMIT=50    # max DENY decision rows one subject may append PER ORG per window before the audit-write becomes a no-op (a soft-DoS wall, keyed per (org, subject) so noise on a decoy org can't blind a victim org's trail; the first N denials per org are still recorded). Success-mutation audits are never throttled
ORGS_DENY_AUDIT_WINDOW=3600    # the fixed window in seconds over which ORGS_DENY_AUDIT_LIMIT applies
APP_ORGS_AUDIT=deny    # org admin-event audit mode: off | deny (log denials, the default) | all

# prompt_registry
PROMPT_REGISTRY_MAX_VERSIONS=1000    # max stored versions per prompt name (creating past the cap is rejected with 422; pinned versions are preserved)
PROMPT_REGISTRY_MAX_LABELS=50    # max named labels per prompt (more is rejected 422)
PROMPT_REGISTRY_MAX_RENDERED_BYTES=262144    # amplification cap: max bytes a rendered template may produce
PROMPT_REGISTRY_MAX_TEMPLATE_BYTES=65536    # max bytes of a stored template (larger is rejected 422)

# rag
RAG_CHUNK_SIZE=400    # chunk window size in CODE POINTS (must be >= 1 and > RAG_CHUNK_OVERLAP)
RAG_CHUNK_OVERLAP=80    # overlap between consecutive chunks in code points (0 <= overlap < RAG_CHUNK_SIZE)
RAG_MAX_CHUNKS=1000    # soft-DoS ceiling: a document needing more than this many chunks is rejected 422

# ratelimit
RATELIMIT_LIMIT=5    # requests allowed per key per window
RATELIMIT_WINDOW=60    # window length in seconds

# rbac
APP_RBAC_AUDIT=deny    # authz decision audit mode: off | deny (log denials, the default) | all

# secrets_vault
SECRETS_VAULT_MAX_VERSIONS=100    # retained versions per secret name (the oldest version is pruned past the cap)
SECRETS_VAULT_KEK=    # base64 of a 32-byte key-encryption key; unset = at-rest sealing OFF (values stored as-is, zero extra deps). Set it to AES-256-GCM seal every secret value at rest (python needs the optional 'cryptography' pip dep; go and node use stdlib). Crypto-shred = destroy this key.
APP_SECRETS_VAULT_AUDIT=all    # secrets access audit mode: off | deny | all (the default)

# storage
STORAGE_PROVIDER=store    # object backend: store (durable, default) or s3 (requires wiring a client)
S3_BUCKET=    # s3 provider: the bucket name (required when STORAGE_PROVIDER=s3)
S3_ENDPOINT=    # s3 provider: the endpoint URL (required when STORAGE_PROVIDER=s3)

# stripe
STRIPE_WEBHOOK_SECRET=whsec_demo_change_me    # the webhook endpoint signing secret (rotate in production)

# webhooks
WEBHOOK_SECRETS=whsec_demo_change_me    # active signing secrets, NEWLINE-separated (multiple = rotation; /send signs with all, /verify accepts any). Rotate in production.

# test-only (the suites set these themselves — NEVER set either one in production)
# APP_TEST_CLOCK=1
# APP_TEST_SESSIONS=1   # would enable test Bearer identities + a fixed test admin — keep unset
